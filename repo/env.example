# RDDA Platform environment template
# Copy this file to repo/.env.local for local development.
# Add the production equivalents in Vercel Project Settings > Environment Variables.
#
# Do not commit real secret values.

# Required for Payload CMS encryption, auth, and admin sessions.
# Generate a long random value before production.
PAYLOAD_SECRET=replace-with-long-random-secret

# Required for Payload Postgres adapter.
# Example providers: Neon, Supabase, Railway, Render, Vercel Postgres-compatible provider.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Public site URL used by public CMS fetch helpers and media URL normalization.
# Local example:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production example:
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.ca
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional explicit Payload server URL.
# Use this if Payload API is served from a different origin than the public site.
# For same-origin deployments, this can usually match NEXT_PUBLIC_SITE_URL.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Optional future media/storage settings.
# These are placeholders for a later storage adapter checkpoint.
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=
